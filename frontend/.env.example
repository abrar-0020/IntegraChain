# Copy this file to .env.local for local overrides, or set these variables
# in your Vercel project dashboard under Settings → Environment Variables.

# Deployed contract address (required for production)
VITE_CONTRACT_ADDRESS=0xYourContractAddressHere

# Chain ID of the network the contract is deployed on
# Common values:
#   31337  - Hardhat local network
#   11155111 - Sepolia testnet
#   1      - Ethereum mainnet
VITE_CHAIN_ID=11155111
