# Copy this file to .env (never commit .env!)
#
# Required for Sepolia deployment:
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY_HERE

# Optional – used for contract verification on Etherscan:
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
